# LMCache Configuration
# Copy this to config.json and modify as needed

{
  "l2_cache": {
    "root_dir": "./l2_cache",
    "max_size_mb": 1024,
    "compression_level": 6,
    "ttl_seconds": 86400
  },
  "maintenance": {
    "cleanup_interval_seconds": 300,
    "cleanup_older_than_hours": 24,
    "disk_warn_threshold": 0.8
  },
  "l3_cache": {
    "host": "localhost",
    "port": 6379,
    "db": 0,
    "prefix": "lmcache:",
    "ttl_seconds": 3600,
    "max_connections": 10,
    "compression_level": 6
  },
  "cache_manager": {
    "enable_promotion": true,
    "lock_timeout": 0.5,
    "fallback_on_timeout": true,
    "lock_poll_interval": 0.05
  },
  "monitoring": {
    "metrics_url": "http://localhost:8000/metrics",
    "gpu_command": "nvidia-smi --query-gpu=memory.used,memory.total --format=csv"
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - %(message)s"
  }
}
